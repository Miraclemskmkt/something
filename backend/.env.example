# 复制为 .env 后按需修改（backend 目录下）

# 爬取模式：search=全网关键词检索（默认）| official=学院官网列表 | both=两者并用
CAMP_CRAWL_MODE=search

# 搜索引擎：bing 或 baidu（百度失败时自动回退 Bing）
CAMP_SEARCH_ENGINE=bing

# 检索策略：broad=泛搜(学校+学院+关键词，推荐) | site=site:域名限定
CAMP_SEARCH_STRATEGY=broad
CAMP_BROAD_SEARCH_MAX_QUERIES=2
CAMP_BROAD_SEARCH_PDF=false
CAMP_SEARCH_COMPACT_KEYWORDS=false

# 单学院预算与超时
CAMP_HTTP_CONNECT_TIMEOUT=4
CAMP_HTTP_READ_TIMEOUT=4
CAMP_COLLEGE_MAX_REQUESTS=15
CAMP_COLLEGE_TOTAL_TIMEOUT_SEC=45
CAMP_COLLEGE_SEARCH_BUDGET_SEC=30
CAMP_COLLEGE_SLOW_THRESHOLD_SEC=12
CAMP_COLLEGE_FAST_TARGET_SEC=10
CAMP_SEARCH_QUERY_TIMEOUT_SEC=5
CAMP_CRAWL_COLLEGE_CONCURRENCY=24
CAMP_SEARCH_MAX_CONCURRENT=12
CAMP_OFFICIAL_LIST_MAX_ITEMS=3
CAMP_FOCUS_CRAWLER_MAX_SEC=5
CAMP_FOCUS_CRAWLER_DEPTH=2
CAMP_FOCUS_CRAWLER_MAX_REQUESTS=5
CAMP_ENRICH_TIMEOUT_LIGHT_SEC=6
CAMP_LIST_PAGE_CACHE_TTL_SEC=86400
CAMP_SEARCH_CACHE_TTL_SEC=7200

# 通知列表自动探测 + 聚焦爬虫（搜索未命中时）
CAMP_NOTICE_LIST_PROBE_ENABLED=true
CAMP_FOCUS_CRAWLER_ENABLED=true

# 检索并发数、每个学院最多检索关键词数
CAMP_SEARCH_MAX_CONCURRENT=3
CAMP_SEARCH_MAX_PER_TARGET=2
CAMP_SEARCH_MAX_DOMAINS=5

# 每检索到 N 条权威通知即写入数据库（默认 10）
CAMP_SEARCH_SAVE_BATCH_SIZE=10

# 快速抓取（默认开启，大幅缩短检索时间）
CAMP_CRAWL_FAST_MODE=true
CAMP_SEARCH_REQUEST_DELAY=0.4
CAMP_SEARCH_MAX_CONCURRENT=8
CAMP_SEARCH_MAX_PER_TARGET=1
CAMP_SEARCH_MAX_DOMAINS=1
CAMP_SEARCH_TARGET_TIMEOUT_SEC=45
CAMP_SEARCH_VERIFY_MAX_RESULTS=2

# 官网抓取
CAMP_FETCH_RETRY_COUNT=1
CAMP_FETCH_JITTER_MAX=0
CAMP_FETCH_PAGE_TIMEOUT=18
CAMP_OFFICIAL_REQUEST_DELAY=0
CAMP_OFFICIAL_LIST_MAX_ITEMS=5

# 补全超时（回填脚本可适当加大）
CAMP_ENRICH_TIMEOUT_SEC=35
CAMP_BING_FALLBACK_MAX_QUERIES=2

# LLM 四字段抽取 — 推荐方案见下方注释
CAMP_LLM_ENABLED=false
CAMP_LLM_PROVIDER=ollama
CAMP_LLM_API_BASE=http://127.0.0.1:11434
CAMP_LLM_MODEL=qwen2.5:7b
CAMP_LLM_TIMEOUT_SEC=60
CAMP_LLM_MAX_CONCURRENT=2
CAMP_LLM_ON_SAVE=true
CAMP_LLM_EXTRACT_FIRST=true
CAMP_LLM_CLASSIFY_ENABLED=true
CAMP_LLM_CLASSIFY_MODEL=qwen2.5:1.5b
CAMP_LLM_CLASSIFY_TIMEOUT_SEC=45
# 论坛帖入库前 1.5b 噪音分类（经验贴/问答 → 丢弃）
CAMP_LLM_FORUM_CLASSIFY_ENABLED=true
# 7b 从论坛正文提取 edu.cn / 微信官方链接（正则兜底）
CAMP_LLM_LINK_EXTRACT_ENABLED=true
# 扩展字段：申请条件/专业/材料/联系方式等，写入 summary 扩展块
CAMP_LLM_ENRICH_ALL_ENABLED=true
CAMP_LLM_CACHE_ENABLED=true
# CAMP_LLM_MULTIMODAL_ENABLED=false
# CAMP_LLM_MULTIMODAL_MODEL=qwen2.5vl:3b

# --- 方案 A：本地 Ollama（推荐，零成本、数据不出本机）---
# 1. 安装 https://ollama.com 后执行：
#    ollama pull qwen2.5:7b          # 16G 内存 CPU 可跑，精度高
#    ollama pull qwen2.5:1.5b        # 8G 内存更快，精度略低
# 2. backend/.env 配置：
# CAMP_LLM_ENABLED=true
# CAMP_LLM_PROVIDER=ollama
# CAMP_LLM_API_BASE=http://127.0.0.1:11434
# CAMP_LLM_MODEL=qwen2.5:7b

# --- 方案 B：智谱 GLM-4-Flash（免费额度，无需本地 GPU）---
# CAMP_LLM_ENABLED=true
# CAMP_LLM_PROVIDER=openai
# CAMP_LLM_API_BASE=https://open.bigmodel.cn/api/paas/v4
# CAMP_LLM_API_KEY=你的智谱APIKey
# CAMP_LLM_MODEL=glm-4-flash

# --- 方案 C：通义千问 DashScope ---
# CAMP_LLM_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
# CAMP_LLM_API_KEY=sk-...
# CAMP_LLM_MODEL=qwen-plus
CAMP_PDF_MAX_BYTES=8000000

# Playwright（慢，仅强 WAF 站点需要）
CAMP_PLAYWRIGHT_ENABLED=false
CAMP_PLAYWRIGHT_TIMEOUT=30
CAMP_PLAYWRIGHT_WAIT_MS=2500

# 是否启用后台定时检索（默认关闭，打开页面直接读数据库）
CAMP_SCHEDULER_ENABLED=false

# 定时检索间隔（分钟），仅 scheduler_enabled=true 时生效
CAMP_CRAWL_INTERVAL_MINUTES=30

# 微信公众号通道 — 手动粘贴链接 + RSS 聚合（推荐）；搜狗搜索默认关闭
CAMP_WECHAT_ENABLED=true
CAMP_WECHAT_SOGOU_ENABLED=false
CAMP_WECHAT_PENDING_ONLY=true
CAMP_WECHAT_REQUEST_DELAY=6
CAMP_WECHAT_SOGOU_DAILY_LIMIT=50
CAMP_WECHAT_SOGOU_WEEKLY_LIMIT=500
CAMP_WECHAT_SNAPSHOT_ENABLED=true
# 保研公众号 RSS：在 data/wechat_rss_feeds.json 填入 feed URL 后启用
CAMP_WECHAT_RSS_ENABLED=true
CAMP_WECHAT_RSS_INTERVAL_HOURS=2

# 保研论坛等网站聚合（推荐，零验证码）
CAMP_BAOYAN_SITES_ENABLED=true
CAMP_BAOYAN_SITES_INTERVAL_HOURS=4
CAMP_BAOYAN_SITES_MAX_THREADS=40
CAMP_BAOYAN_SITES_DELAY=1.5

# 搜狗微信（不推荐，易触发验证码；仅调试时设 true）
# CAMP_WECHAT_SOGOU_ENABLED=false
# CAMP_SOGOU_COOKIE=SUID=...; SUV=...; SNUID=...; ...

# 搜狗微信请求间隔（秒），建议 ≥6
CAMP_WECHAT_MAX_CONCURRENT=1
CAMP_WECHAT_COMPACT_KEYWORDS=true
